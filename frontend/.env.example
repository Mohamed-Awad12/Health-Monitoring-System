VITE_API_URL=http://localhost:5000/api
VITE_SOCKET_URL=http://localhost:5000

# Optional CDN base, for example:
# VITE_CDN_BASE_URL=https://cdn.example.com/pulse/
VITE_CDN_BASE_URL=

VITE_CSRF_COOKIE_NAME=pulse_csrf
VITE_CSRF_HEADER_NAME=x-csrf-token

# Optional CAPTCHA integration.
# Supported providers: hcaptcha, recaptcha
VITE_CAPTCHA_PROVIDER=
VITE_CAPTCHA_SITE_KEY=
