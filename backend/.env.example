PORT=5000
HOST=0.0.0.0
NODE_ENV=development
TRUST_PROXY_HOPS=1

MONGODB_URI=mongodb://127.0.0.1:27017/pulse-oximeter

JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=7d

CORS_ORIGIN=http://localhost:5173
ENFORCE_HTTPS=false

AUTH_COOKIE_NAME=pulse_session
AUTH_COOKIE_DOMAIN=
AUTH_COOKIE_SAME_SITE=lax
AUTH_COOKIE_SECURE=false
CSRF_COOKIE_NAME=pulse_csrf
CSRF_HEADER_NAME=x-csrf-token

SECURITY_LOG_FILE=logs/security-events.log

PATIENT_DASHBOARD_CACHE_TTL_SECONDS=15
READING_FEED_CACHE_TTL_SECONDS=10
DIRECTORY_CACHE_TTL_SECONDS=60
DOCTOR_PATIENTS_CACHE_TTL_SECONDS=15

GLOBAL_RATE_LIMIT_MAX=1000
AUTH_RATE_LIMIT_MAX=20
AUTH_RATE_LIMIT_WINDOW_MINUTES=15
AUTH_ACCOUNT_RATE_LIMIT_MAX=8
AUTH_WRITE_RATE_LIMIT_MAX=90
AUTH_WRITE_RATE_LIMIT_WINDOW_MINUTES=1

CAPTCHA_PROVIDER=
CAPTCHA_SECRET=
CAPTCHA_SITEVERIFY_URL=

PATIENT_LOW_SPO2_THRESHOLD=90
PATIENT_LOW_BPM_THRESHOLD=50
PATIENT_HIGH_BPM_THRESHOLD=120

EMAIL_ALERTS_ENABLED=true
EMAIL_VERIFICATION_TOKEN_TTL_MINUTES=60
PASSWORD_RESET_OTP_TTL_MINUTES=15
EMAIL_VERIFICATION_URL=
EMAIL_WEBHOOK_URL=
EMAIL_WEBHOOK_TIMEOUT_MS=10000
EMAIL_WEBHOOK_AUTH_HEADER=
EMAIL_WEBHOOK_AUTH_VALUE=

ADMIN_BOOTSTRAP_TOKEN=change-this-admin-bootstrap-token

AI_HEALTH_ASSISTANT_API_KEY=
AI_HEALTH_ASSISTANT_MODEL=gpt-4o-mini
AI_HEALTH_ASSISTANT_BASE_URL=https://api.openai.com/v1
AI_HEALTH_ASSISTANT_TIMEOUT_MS=12000
