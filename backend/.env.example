PORT=5000
HOST=0.0.0.0
NODE_ENV=development
MONGODB_URI=mongodb://127.0.0.1:27017/pulse_oximeter
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d
# Comma-separated origins for strict allow-listing; dev also permits private LAN origins.
CORS_ORIGIN=http://localhost:5173
PATIENT_LOW_SPO2_THRESHOLD=90
PATIENT_LOW_BPM_THRESHOLD=50
PATIENT_HIGH_BPM_THRESHOLD=120
EMAIL_ALERTS_ENABLED=true
EMAIL_VERIFICATION_TOKEN_TTL_MINUTES=60
# Password reset also uses a 6-digit OTP.
PASSWORD_RESET_OTP_TTL_MINUTES=15
# Present in config, but the current implementation sends OTP emails instead of clickable verification links.
EMAIL_VERIFICATION_URL=
# Optional. Set this only if you need to create the first admin via the bootstrap API.
ADMIN_BOOTSTRAP_TOKEN=
EMAIL_WEBHOOK_URL=
EMAIL_WEBHOOK_TIMEOUT_MS=10000
EMAIL_WEBHOOK_AUTH_HEADER=
EMAIL_WEBHOOK_AUTH_VALUE=
# For n8n, prefer the production /webhook/ URL after you publish the workflow.
# /webhook-test/ only works while the workflow is listening for a test event.
AI_HEALTH_ASSISTANT_API_KEY=
AI_HEALTH_ASSISTANT_MODEL=gpt-4o-mini
AI_HEALTH_ASSISTANT_BASE_URL=https://api.openai.com/v1
AI_HEALTH_ASSISTANT_TIMEOUT_MS=12000
