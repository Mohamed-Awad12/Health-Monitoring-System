{
  "name": "smart-pulse-oximeter-platform",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "backend",
    "frontend",
    "slides"
  ],
  "scripts": {
    "run:project": "bash ./scripts/run-project.sh",
    "dev": "concurrently \"npm run dev -w backend\" \"npm run dev -w frontend\"",
    "dev:slides": "npm run dev -w slides",
    "build": "npm run build -w frontend",
    "build:slides": "npm run build -w slides",
    "start": "npm run start -w backend"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
